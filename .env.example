# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# Optional: Real Firebase credentials for secure live Authentication and Sync
# Paste from your Firebase Console settings (Web app config / google-services.json)
FIREBASE_API_KEY=PLACEHOLDER_API_KEY
FIREBASE_APPLICATION_ID=PLACEHOLDER_APP_ID
FIREBASE_PROJECT_ID=PLACEHOLDER_PROJECT_ID
FIREBASE_WEB_CLIENT_ID=PLACEHOLDER_WEB_CLIENT_ID
